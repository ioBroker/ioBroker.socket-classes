{
  "name": "@iobroker/socket-classes",
  "version": "2.3.2",
  "description": "ioBroker server-side web sockets",
  "author": {
    "name": "bluefox",
    "email": "dogafox@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ioBroker/ioBroker.socket-classes",
  "keywords": [
    "ioBroker",
    "web",
    "socket",
    "web-socket"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/ioBroker.socket-classes"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.17.0",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/js-controller-common-db": "^7.1.2",
    "@iobroker/ws-server": "^4.4.1",
    "@iobroker/types": "^7.1.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^25.9.2",
    "@types/passport": "^1.0.17",
    "iobroker.js-controller": "^7.1.2",
    "mocha": "^11.7.6",
    "typescript": "~6.0.3"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/ioBroker.socket-classes/issues"
  },
  "main": "build/index.js",
  "files": [
    "LICENSE",
    "build/"
  ],
  "scripts": {
    "lint": "eslint -c eslint.config.mjs",
    "test": "npm run test:integration",
    "test:integration": "mocha --exit",
    "build": "npm run build-backend && npm run docs",
    "build-backend": "tsc -p tsconfig.build.json && node tasks --prebuild",
    "release": "release-script",
    "release-patch": "release-script patch --no-update-lockfile --yes",
    "release-minor": "release-script minor --no-update-lockfile --yes",
    "release-major": "release-script major --no-update-lockfile --yes",
    "update-packages": "npx -y npm-check-updates --upgrade",
    "docs": "node tasks",
    "npm": "npm i -f"
  },
  "license": "MIT",
  "maintainers": [
    {
      "name": "bluefox",
      "email": "dogafox@gmail.com"
    }
  ],
  "overrides": {
    "@iobroker/adapter-core": "^3.3.2"
  }
}
